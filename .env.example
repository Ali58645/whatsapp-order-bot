# --- Meta / WhatsApp Cloud API ---
WHATSAPP_VERIFY_TOKEN=invent-any-secret-string-here
WHATSAPP_ACCESS_TOKEN=your-permanent-system-user-token
WHATSAPP_PHONE_NUMBER_ID=from-meta-dashboard-api-setup
OWNER_WHATSAPP=923001234567

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Flow mode: "order" (food bot) | "lead" (Bahi POS lead gen, default) ---
FLOW_MODE=lead

# --- Coexistence / lead mode ---
BUSINESS_WA_ID=923001234567         # your own business WhatsApp number (echo guard)
CAMPAIGN_PHRASE=Bahi POS            # substring that activates the bot (case-insensitive)
DEMO_SLOT_1=Kal 11am
DEMO_SLOT_2=Kal 4pm

# --- Optional ---
MENU_PATH=menu.json

# --- Google Sheets lead tracking ---
# base64-encode your service account JSON: base64 -i sa.json | tr -d '\n'
GOOGLE_SA_JSON_B64=
GSHEET_ID=your-spreadsheet-id-from-url
GSHEET_TAB=                          # leave blank to use first tab

# --- Postgres (Railway plugin injects DATABASE_URL) ---
# DATABASE_URL=postgresql://...

# --- Admin dashboard (all three required or /dashboard API returns 404) ---
# DASHBOARD_USER=ali              # seeded admin username on first boot (if no users row)
# DASHBOARD_PASSWORD=...          # plain or $2b$ bcrypt hash
# DASHBOARD_JWT_SECRET=long-random-string
